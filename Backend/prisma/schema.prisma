generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  USER
  ADMIN
  SPONSOR
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String
  password  String
  role      Role     @default(USER)
  tickets   Ticket[]
  createdAt DateTime @default(now())
}

model Raffle {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?
  ticket_price  Float
  total_numbers Int
  image_url     String?      
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  tickets       Ticket[]
}


model Ticket {
  id        Int      @id @default(autoincrement())
  number    Int
  raffleId  Int
  userId    Int?
  paymentId Int?
  raffle    Raffle   @relation(fields: [raffleId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Payment {
  id        Int      @id @default(autoincrement())
  reference String
  amount    Float
  status    String
  createdAt DateTime @default(now())
}

model DiscountCode {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  isActive   Boolean  @default(true)
  usedAt     DateTime?
  createdAt DateTime @default(now())
}