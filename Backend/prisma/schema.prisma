generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SPONSOR
}

enum TicketStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum PurchaseStatus {
  PENDING
  PAID
  CANCELLED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String
  password  String
  role      Role     @default(USER)
  tickets   Ticket[]
  createdAt DateTime @default(now())
}

model Raffle {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?
  ticket_price  Float
  total_numbers Int
  image_url     String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  tickets       Ticket[]
  discountCodes DiscountCode[]
  purchases     Purchase[]
}

model Ticket {
  id         Int      @id @default(autoincrement())
  number     Int
  raffleId   Int
  userId     Int?
  purchaseId Int?

  status     TicketStatus @default(AVAILABLE)
  reservedAt DateTime?
  expiresAt  DateTime?

  raffle     Raffle    @relation(fields: [raffleId], references: [id])
  user       User?     @relation(fields: [userId], references: [id])
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([raffleId, number])
}

model DiscountCode {
  id            Int      @id @default(autoincrement())
  code          String
  description   String?
  patrocinador  String?
  image_url     String?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)

  raffleId      Int
  raffle        Raffle   @relation(fields: [raffleId], references: [id])

  purchases     Purchase[]

  usedAt        DateTime?
  validatedBy   Int?

  createdAt     DateTime @default(now())

  @@unique([raffleId, code])
}

model Purchase {
  id                   Int      @id @default(autoincrement())
  buyerName            String
  buyerPhone           String?
  buyerEmail           String
  totalAmount          Float
  status               PurchaseStatus

  raffleId             Int
  raffle               Raffle   @relation(fields: [raffleId], references: [id])

  discountCodeId       Int?
  discountCode         DiscountCode? @relation(fields: [discountCodeId], references: [id])

  validationCode       String? @unique
  validationCodeUsedAt DateTime?

  paymentId            Int?    @unique
  payment              Payment? @relation(fields: [paymentId], references: [id])

  tickets              Ticket[]
  createdAt            DateTime @default(now())
}

model Payment {
  id        Int      @id @default(autoincrement())
  provider  String?
  reference String?
  amount    Float?
  status    String?
  createdAt DateTime @default(now())

  purchase  Purchase?
}
