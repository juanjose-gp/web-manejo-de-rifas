generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  USER
  ADMIN
  SPONSOR
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String
  password  String
  role      Role     @default(USER)
  tickets   Ticket[]
  createdAt DateTime @default(now())
}

model Raffle {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?
  ticket_price  Float
  total_numbers Int
  image_url     String?      
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  tickets       Ticket[]
  discountCodes DiscountCode[]
}



model Ticket {
  id        Int      @id @default(autoincrement())
  number    Int
  raffleId  Int
  userId    Int?
  paymentId Int?

  status     TicketStatus @default(AVAILABLE)
  reservedAt DateTime?
  expiresAt  DateTime?

  raffle    Raffle   @relation(fields: [raffleId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([raffleId, number])
}

enum TicketStatus {
  AVAILABLE
  RESERVED
  SOLD
}


model Payment {
  id        Int      @id @default(autoincrement())
  reference String
  amount    Float
  status    String
  createdAt DateTime @default(now())
}

model DiscountCode {
  id            Int      @id @default(autoincrement())
  code          String
  description   String?
  image_url     String?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)

  raffleId      Int
  raffle        Raffle   @relation(fields: [raffleId], references: [id])

  @@unique([raffleId, code])  

  usedAt        DateTime?
  validatedBy   Int?

  createdAt     DateTime @default(now())
}